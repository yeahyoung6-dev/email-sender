{
  "name": "email-sender",
  "version": "1.0.0",
  "description": "批量点对点邮件发送工具",
  "main": "main.js",
  "author": "yeahyoung6-dev",
  "scripts": {
    "start": "node server.js",
    "build:win": "electron-builder --win --x64"
  },
  "dependencies": {
    "express": "^4.18.2",
    "multer": "^1.4.5-lts.1",
    "nodemailer": "^6.9.8",
    "uuid": "^9.0.0",
    "xlsx": "^0.18.5"
  },
  "devDependencies": {
    "electron": "^28.0.0",
    "electron-builder": "^24.9.1"
  },
  "build": {
    "appId": "com.email-sender.app",
    "productName": "邮件发送工具",
    "directories": {
      "output": "release"
    },
    "files": [
      "**/*",
      "!uploads/*",
      "!release/*"
    ],
    "win": {
      "target": "nsis"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true
    }
  }
}